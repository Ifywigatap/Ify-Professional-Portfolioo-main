# Paystack Public Key (for client-side)
# Get this from your Paystack dashboard
VITE_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email Server (for contact form)
# Use your email provider's SMTP settings
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="you@example.com"
EMAIL_SERVER_PASSWORD="your-email-password-or-app-password"

# Mailchimp (for newsletter) - Optional
MAILCHIMP_API_KEY="your-mailchimp-api-key"
MAILCHIMP_SERVER_PREFIX="usX" # e.g., us1, us2, etc.
MAILCHIMP_AUDIENCE_ID="your-mailchimp-audience-id"

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Plausible Analytics (Optional)
VITE_PLAUSIBLE_DOMAIN="yourdomain.com"